# DO NOT commit real values — this is a template
# Run: kubectl create secret generic gnosis-secrets --from-env-file=.env.prod -n gnosis
apiVersion: v1
kind: Secret
metadata:
  name: gnosis-secrets
  namespace: gnosis
type: Opaque
stringData:
  DB_HOST: postgres
  DB_PORT: "5432"
  DB_USER: postgres
  DB_PASSWORD: REPLACE_WITH_REAL_PASSWORD
  DB_NAME: gnosis
  JWT_SECRET: REPLACE_WITH_REAL_JWT_SECRET_MIN_32_CHARS
  GEMINI_API_KEY: REPLACE_WITH_REAL_GEMINI_API_KEY
  REDIS_URL: redis://redis:6379
  # Email for review notifications (Gmail App Password — NOT your regular password)
  # Generate at: myaccount.google.com → Security → 2FA → App passwords
  SMTP_USER: REPLACE_WITH_GMAIL_ADDRESS
  SMTP_PASS: REPLACE_WITH_GMAIL_APP_PASSWORD
  ADMIN_EMAIL: shivamkumarbxr8@gmail.com
  SITE_URL: http://80.225.228.31
