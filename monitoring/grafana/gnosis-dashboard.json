{
  "title": "Gnosis — Service Overview",
  "uid": "gnosis-overview",
  "description": "RED metrics (Rate, Errors, Duration) + DB health for all Gnosis microservices",
  "tags": ["gnosis", "microservices", "red"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "current": { "value": "gnosis" },
        "hide": 2
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up{namespace=\"gnosis\"}, job)",
        "label": "Service",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Services Up", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(up{namespace=\"$namespace\"})", "legendFormat": "Up" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 8 }] } } }
    },
    {
      "id": 2, "title": "Request Rate (req/s)", "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[5m]))", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3, "title": "Error Rate", "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total{namespace=\"$namespace\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"$namespace\"}[5m])) * 100", "legendFormat": "%" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 4, "title": "P95 Latency", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))) * 1000", "legendFormat": "ms" }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } }
    },
    {
      "id": 5, "title": "Pod Restarts (1h)", "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[1h]))", "legendFormat": "restarts" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 6, "title": "Active Battle Rooms", "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "socket_io_connected{namespace=\"$namespace\", job=\"battle-service\"}", "legendFormat": "rooms" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10, "title": "HTTP Request Rate per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (job) (rate(http_requests_total{namespace=\"$namespace\", job=~\"$service\"}[5m]))", "legendFormat": "{{ job }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11, "title": "Error Rate per Service (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (job) (rate(http_requests_total{namespace=\"$namespace\", status=~\"5..\", job=~\"$service\"}[5m])) / sum by (job) (rate(http_requests_total{namespace=\"$namespace\", job=~\"$service\"}[5m])) * 100", "legendFormat": "{{ job }}" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 12, "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, job) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$service\"}[5m]))) * 1000", "legendFormat": "p50 {{ job }}" },
        { "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$service\"}[5m]))) * 1000", "legendFormat": "p95 {{ job }}" },
        { "expr": "histogram_quantile(0.99, sum by (le, job) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$service\"}[5m]))) * 1000", "legendFormat": "p99 {{ job }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 20, "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (container) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container!="", container!="POD"}[5m])) * 100", "legendFormat": "{{ container }}" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 21, "title": "Memory Usage by Container",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (container) (container_memory_usage_bytes{namespace=\"$namespace\", container!="", container!="POD"})", "legendFormat": "{{ container }}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 30, "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 6 },
      "targets": [{ "expr": "pg_stat_activity_count{namespace=\"$namespace\", datname=\"gnosis\"}", "legendFormat": "connections" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] } } }
    },
    {
      "id": 31, "title": "Redis Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 6 },
      "targets": [{ "expr": "redis_memory_used_bytes{namespace=\"$namespace\"}", "legendFormat": "used" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 32, "title": "Battle Service — Socket Connections",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 6 },
      "targets": [{ "expr": "socket_io_connected{namespace=\"$namespace\", job=\"battle-service\"}", "legendFormat": "connected" }]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
